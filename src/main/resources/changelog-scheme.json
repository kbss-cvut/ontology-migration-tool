{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Changelog Schema",
  "type": "object",
  "required": ["changeSets"],
  "properties": {
    "changeSets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "changes"],
        "properties": {
          "id": { "type": ["string", "number"] },
          "changes": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["type", "oldIri", "newIri"],
                  "properties": {
                    "type": { "const": "renameResource" },
                    "oldIri": { "type": "string" },
                    "newIri": { "type": "string" },
                    "graph": {"type":  "string"}
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "iri"],
                  "properties": {
                    "type": { "const": "addClass" },
                    "iri": { "type": "string" },
                    "label": { "type": "string" },
                    "graph": {"type":  "string"}
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "iri"],
                  "properties": {
                    "type": { "const": "addResource" },
                    "iri": { "type": "string" },
                    "classIri": { "type": "string" },
                    "label": { "type": "string" },
                    "graph": {"type":  "string"}
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "propertyIRI"],
                  "properties": {
                    "type": { "const": "addProperty" },
                    "subjectIRI": { "type": "string" },
                    "propertyIRI": { "type": "string" },
                    "objectIRI": { "type": "string" },
                    "graph": {"type":  "string"}
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "iri"],
                  "properties": {
                    "type": { "const": "deleteResource" },
                    "iri": { "type": "string" },
                    "graph": {"type":  "string"}
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "query"],
                  "properties": {
                    "type": { "const": "sparqlUpdate" },
                    "query": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}